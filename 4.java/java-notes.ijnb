    {
      "id": "5d7cf193-f8d8-4221-aded-aa591320de45",
      "cell_type": "code",
      "source": "import com.ucmmaster.kafka.simple.*;\nimport org.apache.kafka.clients.producer.KafkaProducer;\nimport org.apache.kafka.clients.producer.ProducerRecord;",
